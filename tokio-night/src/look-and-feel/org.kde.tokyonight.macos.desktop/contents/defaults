[kcminputrc][Mouse]
cursorTheme=breeze_cursors

[kdeglobals][General]
ColorScheme=TokyoNight

[kdeglobals][Icons]
Theme=breeze-dark

[kdeglobals][KDE]
widgetStyle=Breeze

[kwinrc][DesktopSwitcher]
LayoutName=org.kde.breeze.desktop

[kwinrc][WindowSwitcher]
LayoutName=org.kde.breeze.desktop

[kwinrc][org.kde.kdecoration2]
library=org.kde.kwin.aurorae
theme=__aurorae__svg__TokyoNight-Dark

[plasmarc][Theme]
name=Tokyo-Night

[ksplashrc][KSplash]
Theme=org.kde.tokyonight.macos.desktop

[kwinrc][Plugins]
better_blur_dxEnabled=true
blurEnabled=false

[kwinrc][Effect-better-blur-dx]
BlurStrength=8
NoiseStrength=2
BlurDocks=true
BlurMenus=true
BlurDecorations=true
BlurNonMatching=true

[kwinrc][Effect-translucency]
Dialogs=89
Inactive=90
MoveResize=90

[kcminputrc][Mouse]
cursorTheme=breeze_cursors

[kdeglobals][General]
ColorScheme=TokyoNight

[kdeglobals][Icons]
Theme=breeze-dark

[kdeglobals][KDE]
widgetStyle=Breeze

[kwinrc][DesktopSwitcher]
LayoutName=org.kde.breeze.desktop

[kwinrc][WindowSwitcher]
LayoutName=org.kde.breeze.desktop

[kwinrc][org.kde.kdecoration2]
library=org.kde.klassy
theme=Klassy
ButtonsOnLeft=XIA
ButtonsOnRight=

[plasmarc][Theme]
name=Tokyo-Night

[ksplashrc][KSplash]
Theme=org.kde.tokyonight.macos.desktop

[kwinrc][Plugins]
better_blur_dxEnabled=true
blurEnabled=false

[kwinrc][Effect-better-blur-dx]
BlurStrength=8
NoiseStrength=2
BlurDocks=true
BlurMenus=true
BlurDecorations=true
BlurNonMatching=true
CornerRadius=6

[kwinrc][Effect-translucency]
Dialogs=89
Inactive=90
MoveResize=90

# The Klassy decoration style (macOS small circular traffic-light buttons in Tokyo
# Night colours, no window outline) is shipped as a Klassy preset at
# ../../../klassy/TokyoNight.klpw and applied by install.sh via:
#   klassy-settings --import-preset klassy/TokyoNight.klpw
#   klassy-settings --load-windeco-preset TokyoNight
# (Klassy reads ~/.config/klassy/klassyrc, which a Look & Feel `defaults` file
#  cannot target, so the style is not embedded here.)
